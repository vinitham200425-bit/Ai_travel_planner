generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Trip {
  id            String   @id @default(cuid())
  destination   String
  days          Int
  budget        Int
  travelers     String
  travelStyle   String
  hotelCategory String
  itinerary     String

  createdAt     DateTime @default(now())
}